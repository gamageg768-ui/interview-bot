datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth models (NextAuth v4 / PrismaAdapter) ────────────────────────────────

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  interviewSessions InterviewSession[]
  pipelines         Pipeline[]
  vivaSessions      VivaSession[]
  vivaPersonas      VivaPersona[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Interview models ─────────────────────────────────────────────────────────

model InterviewSession {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String
  role           String
  context        String    @default("")
  difficulty     String
  totalQuestions Int
  averageScore   Float
  completedAt    DateTime  @default(now())
  stressMode     Boolean   @default(false)
  answers        Answer[]
}

model Answer {
  id         String           @id @default(cuid())
  sessionId  String
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   String
  userAnswer String
  score      Int
  feedback   String
  createdAt  DateTime         @default(now())
}

model Bookmark {
  id           String   @id @default(cuid())
  userId       String?
  questionText String
  type         String
  category     String
  role         String
  savedAt      DateTime @default(now())
}

// ── Pipeline models ──────────────────────────────────────────────────────────

model Pipeline {
  id          String          @id @default(cuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  stages      PipelineStage[]
  status      String          @default("pending")
  createdAt   DateTime        @default(now())
  completedAt DateTime?
}

model PipelineStage {
  id            String    @id @default(cuid())
  pipelineId    String
  pipeline      Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  type          String
  role          String
  difficulty    String
  questionCount Int
  stageOrder    Int
  averageScore  Float?
  sessionId     String?
  completedAt   DateTime?
}

// ── Viva Exam models ─────────────────────────────────────────────────────────

model VivaSession {
  id                 String       @id
  userId             String?
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  discipline         String
  topic              String
  difficulty         String
  candidateName      String?
  examinerName       String?
  allowInterruptions Boolean      @default(true)
  personaId          String?
  model              String?
  createdAt          BigInt
  endedAt            BigInt?
  verdict            String?
  rubricScores       String?
  turns              VivaTurn[]
}

model VivaTurn {
  id          String      @id
  sessionId   String
  session     VivaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  text        String
  timestamp   BigInt
  interrupted Boolean     @default(false)
}

model VivaPersona {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  background     String
  specialization String?
  institution    String?
  createdAt      DateTime @default(now())
}

model VivaStudyMaterial {
  id              String @id
  sessionId       String @unique
  userId          String
  flashcards      String
  outline         String
  recommendations String
  createdAt       BigInt
}

model VivaWeakArea {
  id        String @id
  sessionId String
  userId    String
  topic     String
  severity  Int    @default(5)
  createdAt BigInt
}

model VivaShareToken {
  token     String @id
  sessionId String
  userId    String
  expiresAt BigInt
  createdAt BigInt
}

model VivaAnnotation {
  id        String @id
  turnId    String
  sessionId String
  userId    String
  note      String
  createdAt BigInt
}
